<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <Button
        android:id="@+id/btnBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="← Înapoi"
        android:backgroundTint="#808080"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Meci Nou"
        android:textSize="32sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="32dp"/>

    <EditText
        android:id="@+id/etMatchTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Sport / Titlu "
        android:inputType="text"
        android:minHeight="48dp"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/etMatchLocation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Locație"
        android:inputType="text"
        android:minHeight="48dp"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/etMatchTime"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Data (Format: 2026-03-25T18:00:00)"
        android:inputType="text"
        android:minHeight="48dp"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnSubmitMatch"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Salvează Meciul"
        android:textSize="18sp"
        android:textStyle="bold"/>

</LinearLayout>